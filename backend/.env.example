# ==========================================
# backend/.env.example
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ==========================================

# --- Groq LLM ---
# Get key at https://console.groq.com
# ROTATE THIS KEY if it was ever in a dev environment or git history.
GROQ_API_KEY=your_groq_api_key_here

# --- Deepgram STT (voice input for the chat assistant) ---
# Get key at https://console.deepgram.com
# ROTATE THIS KEY if it was ever in a dev environment or git history.
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# --- Database ---
# Local dev (SQLite — no setup required):
DATABASE_URL=sqlite:///./student.db

# Production (Neon Postgres):
# 1. Sign up free at https://neon.tech
# 2. Create a project, copy the connection string
# DATABASE_URL=postgresql+psycopg2://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- CORS ---
# Local dev:
ALLOWED_ORIGINS=*
# Production (replace with your Cloudflare Pages URL):
# ALLOWED_ORIGINS=https://yourapp.pages.dev

# --- JWT (Phase 2) ---
# Generate a secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_BEFORE_DEPLOY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
